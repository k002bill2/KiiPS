  "code-simplifier": {
    "type": "agent",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Post-implementation code refactoring and simplification (Boris Cherny principle)",
    "agentFile": ".claude/agents/code-simplifier.md",
    "model": "haiku",
    "autoActivationLevel": "manual",
    "promptTriggers": {
      "keywords": [
        "simplify",
        "단순화",
        "refactor",
        "리팩토링",
        "개선",
        "improve",
        "cleanup",
        "정리",
        "복잡",
        "complex",
        "complicated"
      ],
      "intentPatterns": [
        "(simplify|단순화).*?(code|코드)",
        "(refactor|리팩토링).*?(this|이|code|코드)",
        "(code|코드).*?(too|너무).*?(complex|복잡)",
        "(improve|개선).*?(code|코드|quality|품질)",
        "(cleanup|정리).*?(code|코드)",
        "(reduce|줄이|감소).*?(complexity|복잡도)"
      ]
    },
    "triggeredAfter": [
      "기능 구현 완료",
      "feature implementation complete",
      "/review shows high complexity"
    ],
    "capabilities": {
      "detectComplexity": true,
      "extractMethod": true,
      "guardClauses": true,
      "extractConditional": true,
      "eliminateDuplication": true,
      "preserveBehavior": true
    },
    "thresholds": {
      "cyclomaticComplexity": 10,
      "nestingDepth": 3,
      "methodLength": 50,
      "duplicationMinLines": 5
    }
  },

