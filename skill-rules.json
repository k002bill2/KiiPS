{
  "kiips-frontend-guidelines": {
    "type": "guideline",
    "enforcement": "suggest",
    "priority": "high",
    "promptTriggers": {
      "keywords": ["JSP", "JavaScript", "UI", "프론트엔드", "화면", "페이지", "jQuery"],
      "intentPatterns": [
        "(create|update|modify).*?(page|screen|UI|화면)",
        "(fix|style).*?(JSP|JavaScript)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/jsp/**/*.jsp", "**/static/**/*.js", "**/static/**/*.css"],
      "contentPatterns": ["<%@", "$(document)", "function "]
    }
  },

  "kiips-security-guide": {
    "type": "guardrail",
    "enforcement": "require",
    "priority": "critical",
    "description": "KiiPS 보안 가이드 - Spring Security, XSS 방어, CSRF, 인증/인가, 민감정보 보호",
    "promptTriggers": {
      "keywords": ["인증", "로그인", "JWT", "토큰", "비밀번호", "암호화", "보안", "XSS", "CSRF"],
      "intentPatterns": [
        ".*?(auth|login|token).*?",
        ".*?(password|secret|encrypt).*?",
        "(보안|security).*?(설정|config|check|검증)"
      ]
    }
  },

  "kiips-feature-planner": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "managerAgent": "feature-manager",
    "orchestrationSkill": "kiips-orchestration",
    "autoActivationLevel": "manager",
    "delegationRules": {
      "managerHandles": "기능 개발 라이프사이클 조정, 단계별 handoff (architect→developer→QA), 품질 체크포인트 강제, dev docs 관리",
      "workerHandles": "아키텍처 설계 (kiips-architect), 코드 구현 (kiips-developer), UI 개발 (kiips-ui-designer), 검증 (checklist-generator)"
    },
    "promptTriggers": {
      "keywords": ["기능", "feature", "개발", "계획", "plan", "구현", "implement"],
      "intentPatterns": [
        "(새로운|new).*?(기능|feature)",
        "(개발|develop).*?(계획|plan)",
        "(구현|implement).*?(기능|feature)",
        "feature.*?(추가|add|create)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["dev/active/**/*-plan.md"],
      "contentPatterns": ["## Implementation Plan", "## Phase"]
    }
  },

  "kiips-ui-component-builder": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "JSP 컴포넌트 템플릿 기반 생성 (RealGrid, ApexCharts, Bootstrap 폼, 팝업)",
    "managerAgent": "ui-manager",
    "orchestrationSkill": "kiips-orchestration",
    "autoActivationLevel": "worker",
    "delegationRules": {
      "managerHandles": "UI 컴포넌트 구현 계획, 템플릿 선택 조정, 검증 파이프라인 조정 (반응형→접근성→크로스브라우저)",
      "workerHandles": "JSP 파일 생성, RealGrid 초기화 코드, ApexCharts 설정, Bootstrap 레이아웃, SCSS 스타일 작성, 팝업 템플릿 생성"
    },
    "promptTriggers": {
      "keywords": [
        "UI 컴포넌트",
        "JSP 생성",
        "그리드 생성",
        "차트 추가",
        "페이지 생성",
        "화면 개발",
        "컴포넌트 템플릿",
        "펀드 목록",
        "투자 대시보드",
        "검색 폼",
        "모달 팝업",
        "탭 레이아웃",
        "팝업",
        "popup",
        "POPUP",
        "print",
        "인쇄",
        "모달",
        "modal"
      ],
      "intentPatterns": [
        "(create|생성|만들).*?(UI|component|컴포넌트|page|페이지|screen|화면)",
        "(add|추가).*?(grid|그리드|chart|차트|form|폼|modal|모달)",
        "(build|develop).*?(JSP|화면|페이지)",
        "(new|새).*?(page|화면|component|컴포넌트)",
        "팝업.*?(만들|생성|추가)",
        "popup.*?(create|generate|add)",
        "(인쇄|print).*?(페이지|page|popup|팝업)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.jsp", "**/webapp/**/*.html", "**/POPUP*.jsp", "**/popup*.jsp", "**/*_print*.jsp"],
      "contentPatterns": ["RealGridJS", "ApexCharts", "Bootstrap", "header_popup.jsp", "print.css", "no-print"]
    },
    "referenceFiles": ["docs/POPUP_GUIDE.md", "docs/SCSS_GUIDE.md"]
  },

  "kiips-realgrid-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "RealGrid 2.6.3 종합 가이드 - 그리드 생성, 설정, 에디터, Excel, 성능 최적화",
    "managerAgent": "ui-manager",
    "orchestrationSkill": "kiips-orchestration",
    "autoActivationLevel": "worker",
    "delegationRules": {
      "managerHandles": "RealGrid 생성/설정 감독, 멀티 레벨 헤더 설계 검토, KiiPS 표준 패턴 검증, Excel export/import 전략, 성능 최적화",
      "workerHandles": "GridView/DataProvider 초기화, 컬럼 정의 생성, 멀티 레벨 헤더 구현, 커스텀 렌더러 연동, 셀 에디터 설정, 필터/정렬/그룹핑 구현"
    },
    "promptTriggers": {
      "keywords": [
        "RealGrid",
        "리얼그리드",
        "그리드",
        "테이블",
        "그리드 생성",
        "그리드 만들어",
        "테이블 생성",
        "멀티 레벨 헤더",
        "컬럼 그룹",
        "columnLayout",
        "createMainGrid",
        "그리드 설정",
        "그리드 편집",
        "셀 에디터",
        "엑셀 내보내기",
        "엑셀 가져오기",
        "그리드 필터",
        "그리드 정렬",
        "그룹핑",
        "집계"
      ],
      "intentPatterns": [
        "(create|생성|만들).*?(RealGrid|그리드|table|테이블)",
        "(멀티|multi).*?(level|레벨).*?(header|헤더)",
        "(columnLayout|컬럼 그룹).*?",
        "(RealGrid|그리드).*?(코드|code).*?(생성|generate)",
        "RealGrid.*?(설정|config|setup|configure)",
        "(grid|그리드).*?(edit|편집|export|내보내기|import|가져오기)",
        "(Excel|엑셀).*?(export|import|다운로드|업로드)",
        "(cell|셀).*?(editor|에디터|edit|편집)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*grid*.js", "**/*Grid*.js", "**/*.jsp"],
      "contentPatterns": ["RealGridJS", "GridView", "DataProvider", "createMainGrid", "logosAjax.requestTokenGrid", "setColumnLayout", "setFields", "setColumns"]
    },
    "referenceFiles": ["docs/REALGRID_GUIDE.md", "docs/SCSS_GUIDE.md"]
  },

  "checklist-generator": {
    "type": "tool",
    "enforcement": "suggest",
    "priority": "normal",
    "managerAgent": "shared",
    "orchestrationSkill": "shared",
    "autoActivationLevel": "worker",
    "delegationRules": {
      "managerHandles": "체크리스트 요청 조정, 체크포인트 타이밍 결정, 검증 결과 평가",
      "workerHandles": "도메인별 체크리스트 생성 (빌드, 배포, 코드 리뷰, UI 검증, 테스트)",
      "sharedBy": ["build-manager", "feature-manager", "ui-manager", "deployment-manager"]
    },
    "promptTriggers": {
      "keywords": [
        "checklist",
        "체크리스트",
        "TODO",
        "todo",
        "task list",
        "verification",
        "검증",
        "확인사항",
        "점검"
      ],
      "intentPatterns": [
        "(create|generate|make|생성|작성).*?(checklist|체크리스트|TODO|task list)",
        "(code review|deployment|testing).*?(checklist|체크리스트)",
        "(verify|check|validate).*?(list|items|체크)",
        "what.*?(should|need).*?(check|verify|confirm)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/*-checklist.md",
        "**/checklists/**",
        "**/TODO.md"
      ]
    }
  },

  "kiips-test-runner": {
    "type": "validation",
    "enforcement": "require",
    "priority": "critical",
    "description": "Automated test execution (Boris Cherny's feedback loop principle)",
    "autoActivationLevel": "hook",
    "triggeredBy": "stopEvent Hook",
    "promptTriggers": {
      "keywords": [
        "테스트",
        "test",
        "junit",
        "검증",
        "validation",
        "테스트 실행",
        "run test",
        "자동 테스트",
        "auto test",
        "test coverage",
        "커버리지"
      ],
      "intentPatterns": [
        "(run|실행|execute).*?(test|테스트)",
        "(test|테스트).*?(자동|auto|automatic)",
        "(verify|검증|validate).*?(code|코드)",
        "(junit|karma|jest).*?(test|테스트)",
        "(coverage|커버리지).*?(check|확인|measure)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/*Test.java",
        "**/*Tests.java",
        "**/test/**/*.java",
        "**/*.test.js",
        "**/*.spec.js",
        "**/test/**/*.js"
      ],
      "contentPatterns": [
        "@Test",
        "@RunWith",
        "describe\\(",
        "it\\(",
        "test\\("
      ]
    },
    "activationConditions": {
      "automatic": "Triggered by stopEvent Hook when .java files are modified",
      "manual": "Can be invoked explicitly for test execution",
      "preventDuplicates": true
    }
  },

  "code-simplifier": {
    "type": "agent",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Post-implementation code refactoring and simplification (Boris Cherny principle)",
    "agentFile": ".claude/agents/code-simplifier.md",
    "model": "haiku",
    "autoActivationLevel": "manual",
    "promptTriggers": {
      "keywords": [
        "simplify",
        "단순화",
        "refactor",
        "리팩토링",
        "개선",
        "improve",
        "cleanup",
        "정리",
        "복잡",
        "complex",
        "complicated"
      ],
      "intentPatterns": [
        "(simplify|단순화).*?(code|코드)",
        "(refactor|리팩토링).*?(this|이|code|코드)",
        "(code|코드).*?(too|너무).*?(complex|복잡)",
        "(improve|개선).*?(code|코드|quality|품질)",
        "(cleanup|정리).*?(code|코드)",
        "(reduce|줄이|감소).*?(complexity|복잡도)"
      ]
    },
    "triggeredAfter": [
      "기능 구현 완료",
      "feature implementation complete",
      "/review shows high complexity"
    ],
    "capabilities": {
      "detectComplexity": true,
      "extractMethod": true,
      "guardClauses": true,
      "extractConditional": true,
      "eliminateDuplication": true,
      "preserveBehavior": true
    },
    "thresholds": {
      "cyclomaticComplexity": 10,
      "nestingDepth": 3,
      "methodLength": 50,
      "duplicationMinLines": 5
    }
  },

  "kiips-page-pattern-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "KiiPS JSP 페이지 표준 패턴 - 레이아웃, Include 체계, 검색필터+버튼+그리드 연동",
    "promptTriggers": {
      "keywords": ["페이지 생성", "화면 만들", "JSP 만들", "새 화면", "페이지 패턴", "표준 패턴", "페이지 템플릿", "목록 화면"],
      "intentPatterns": [
        "(페이지|화면|JSP).*(생성|만들|추가|제작)",
        "(create|add|make).*(page|screen|jsp)",
        "(표준|standard).*(패턴|pattern).*(적용|apply)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/WEB-INF/jsp/kiips/**/*.jsp"],
      "contentPatterns": ["inc_filter_main", "inc_main_button", "MAIN_SEARCH_FILTER", "content-body-modern"]
    }
  },

  "kiips-search-filter-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "KiiPS 검색필터 패턴 - MainComponent, Constant, inc_filter_main.jsp 연동",
    "promptTriggers": {
      "keywords": ["검색조건", "검색필터", "SEARCH_CONDITION", "MainComponent", "필터", "inc_filter_main"],
      "intentPatterns": [
        "(검색|필터|조건).*(추가|생성|만들|수정)",
        "(create|add|make).*(filter|search|condition)",
        "SEARCH_CONDITION.*(추가|변경|수정)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/WEB-INF/jsp/**/*.jsp"],
      "contentPatterns": ["SEARCH_CONDITION", "MainComponent", "inc_filter_main", "MAIN_SEARCH_FILTER"]
    }
  },

  "kiips-button-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "KiiPS 버튼 영역 패턴 - inc_main_button, 권한, 아이콘",
    "promptTriggers": {
      "keywords": ["버튼", "툴바", "inc_main_button", "btn_reload", "btn_regist", "관리자 버튼", "엑셀 버튼"],
      "intentPatterns": [
        "(버튼|toolbar|툴바).*(추가|생성|만들|수정)",
        "(create|add|make).*(button|toolbar)",
        "inc_(il|fd|ac|pg)_button"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/include/button/inc_*_button.jsp", "**/include/inc_main_button.jsp"],
      "contentPatterns": ["inc_main_button", "maingrid_button", "btn_reload", "btn_regist"]
    }
  },

  "kiips-regist-modal-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "KiiPS 등록/수정 모달 패턴 - 모달 HTML, 폼필드, 편집그리드, columnGroup 머지, 저장",
    "promptTriggers": {
      "keywords": ["등록 모달", "수정 모달", "모달창", "팝업", "registModal", "modal 생성", "모달 그리드"],
      "intentPatterns": [
        "(등록|수정|모달|팝업).*(생성|만들|추가)",
        "modal.*(add|create)",
        "(columnGroup|컬럼그룹).*(머지|merge)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/WEB-INF/jsp/**/*.jsp"],
      "contentPatterns": ["modal fade", "modal-dialog", "bottom-btn", "modal-confirm"]
    }
  },

  "kiips-mybatis-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "MyBatis 종합 가이드 - #{} vs ${}, mapper.xml 패턴, 동적 SQL",
    "promptTriggers": {
      "keywords": ["MyBatis", "마이바티스", "mapper", "매퍼", "SQL", "쿼리", "동적SQL"],
      "intentPatterns": [
        "(mybatis|마이바티스).*(작성|생성|수정)",
        "(mapper|매퍼).*(xml|작성|추가)",
        "(SQL|쿼리).*(바인딩|binding|injection)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/mapper/**/*.xml"],
      "contentPatterns": ["#{", "${", "<select", "<insert", "<update", "<delete"]
    },
    "blockRules": [
      {
        "id": "ddl-destructive",
        "pattern": "\\b(DROP|TRUNCATE)\\s+(TABLE|INDEX|COLUMN)",
        "message": "DDL 파괴 명령 차단: DBA 승인 필수",
        "severity": "critical"
      },
      {
        "id": "delete-without-where",
        "pattern": "DELETE\\s+FROM\\s+\\w+\\s*$",
        "message": "WHERE 없는 DELETE 차단: 대량 삭제 위험",
        "severity": "critical"
      }
    ]
  },

  "legacy-compliance-checker": {
    "type": "guardrail",
    "enforcement": "block",
    "priority": "critical",
    "description": "KiiPS 레거시 호환성 검증 - Java 8, Spring Boot 2.4.x, jQuery/JSP 표준",
    "promptTriggers": {
      "keywords": ["Java", "코드 작성", "구현", "implement", "클래스", "메서드", "controller", "service"],
      "intentPatterns": [
        "(create|add|write|작성|생성).*?(class|method|controller|service|dao|mapper)",
        "(implement|구현).*?(feature|기능|API|endpoint)",
        "(upgrade|업그레이드|migration|마이그레이션).*?(java|spring|version)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.java", "**/*.jsp", "**/*.xml", "**/*.scss"],
      "contentPatterns": ["public class", "public interface", "<%@", "@import"]
    },
    "blockRules": [
      {
        "id": "java8-syntax",
        "pattern": "\\bvar\\s+\\w+\\s*=|\\brecord\\s+\\w+|\\bsealed\\s+(class|interface)",
        "message": "Java 8 호환성 위반: var/record/sealed는 Java 10+ 문법입니다",
        "severity": "critical"
      },
      {
        "id": "dark-theme-selector",
        "pattern": "\\.(dark|theme-dark)\\s*\\{",
        "message": "[data-theme=dark] 셀렉터만 사용하세요 (.dark, .theme-dark 금지)",
        "severity": "high"
      },
      {
        "id": "mybatis-injection",
        "pattern": "\\$\\{(?!\\s*(sortColumn|sortDirection|orderBy)\\s*[},])",
        "message": "MyBatis ${} 직접 삽입은 SQL Injection 위험 (ORDER BY 예외만 허용)",
        "severity": "critical"
      }
    ]
  },

  "kiips-db-inspector": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "DB 구조 조회 전용 - MyBatis mapper 분석, 테이블/컬럼 탐색",
    "promptTriggers": {
      "keywords": ["테이블 구조", "컬럼", "DB 구조", "스키마 확인", "mapper 분석", "TB_", "DAO 매핑"],
      "intentPatterns": [
        "(테이블|table|TB_).*?(구조|structure|확인|조회)",
        "(컬럼|column).*?(목록|list|확인|what)",
        "(mapper|매퍼).*?(분석|analyze|확인)",
        "(DB|database|디비).*?(구조|schema|inspect)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/mapper/**/*.xml", "**/dao/**/*.java"],
      "contentPatterns": ["resultMap", "namespace", "@Mapper"]
    },
    "readOnlyConstraint": true
  },

  "kiips-linked-approval-template": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "결재 연계 문서(LinkedApproval) HTML 템플릿 + 데이터 바인딩 생성",
    "promptTriggers": {
      "keywords": ["결재", "상신", "LinkedApproval", "결재 연계", "결재 템플릿", "상신 문서"],
      "intentPatterns": [
        "(결재|approval).*?(연계|linked|템플릿|template)",
        "(상신|submit).*?(문서|document|생성|create)",
        "LinkedApproval.*?(생성|추가|만들)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/static/js/LinkedApproval*.js"],
      "contentPatterns": ["LinkedApprovalCode", "getApprvContent", "doc_id"]
    }
  },

  "kiips-build": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "KiiPS 빌드/배포 통합 - Maven 빌드, 서비스 배포, 시작/중지, Pre-flight 체크",
    "promptTriggers": {
      "keywords": ["빌드", "배포", "build", "deploy", "maven", "mvn", "start", "stop", "restart", "startup", "compile", "package"],
      "intentPatterns": [
        "(build|compile|package).*?(service|module|project)",
        "(start|stop|restart|deploy).*?service",
        ".*?(배포|시작|중지|재시작).*?서비스",
        ".*?KiiPS-(FD|IL|PG|COMMON|UTILS).*?(build|빌드)",
        "(how to|need to).*?build",
        "(서비스|service).*(시작|start|기동)",
        "(pre-flight|preflight|점검).*(check|확인)",
        "check.*?(health|status)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/pom.xml", "**/start.sh", "**/stop.sh"],
      "contentPatterns": ["<artifactId>KiiPS-", "<packaging>"]
    }
  },

  "kiips-logs": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "high",
    "description": "KiiPS 로그 분석 및 조회 - 에러 탐지, 스택 트레이스 분석, 구조화된 로그 검색",
    "promptTriggers": {
      "keywords": ["로그", "log", "error", "에러", "exception", "분석", "로그 보기", "로그 검색"],
      "intentPatterns": [
        "(check|analyze|find).*?(log|error)",
        ".*?(로그|에러).*?(확인|분석|검색)",
        "(troubleshoot|debug).*?issue",
        "(로그|log).*?(보기|보여|조회|search|filter|읽기|read)",
        "(최근|오늘|어제|recent|today).*?(로그|log)",
        "(서비스|service).*?(로그|log).*?(확인|check)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/logs/*.log"]
    },
    "readOnlyConstraint": true
  },

  "kiips-backend": {
    "type": "guideline",
    "enforcement": "suggest",
    "priority": "high",
    "description": "KiiPS 백엔드 개발 가이드 - Controller/Service/DAO 표준 패턴, API 설계, 공통 모듈",
    "promptTriggers": {
      "keywords": ["controller", "service", "dao", "API", "endpoint", "REST", "COMMON", "UTILS", "공통"],
      "intentPatterns": [
        "(create|add|make).*?(controller|service|endpoint)",
        "(fix|debug).*?(API|service)",
        "(how to|best practice).*?(backend|controller)",
        "(use|implement).*?(common|shared|util)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/controll/**/*.java", "**/service/**/*.java", "**/dao/**/*.java", "**/KiiPS-COMMON/**/*.java", "**/KiiPS-UTILS/**/*.java"],
      "contentPatterns": ["@RestController", "@Service", "extends DAO"]
    }
  },

  "kiips-learning": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "KiiPS 연속 학습 시스템 - Instinct 생성, 패턴 감지, 스킬/커맨드 진화 및 자동 생성",
    "promptTriggers": {
      "keywords": ["학습", "패턴", "instinct", "skill factory", "스킬 생성"],
      "intentPatterns": [
        "(학습|learn).*?(패턴|pattern|instinct)",
        "(관찰|observe).*?(세션|session)",
        "(진화|evolve).*?(스킬|skill|커맨드|command)",
        "(create|generate|make).*?skill",
        "(자동|auto).*?(스킬|skill|커맨드|command)",
        "패턴.*?스킬.*?생성"
      ]
    }
  },

  "kiips-orchestration": {
    "type": "framework",
    "enforcement": "require",
    "priority": "critical",
    "description": "ACE Framework 기반 오케스트레이션 - 병렬 에이전트 조정, 스킬 체이닝 파이프라인, ACE 핵심 가드레일",
    "promptTriggers": {
      "keywords": ["병렬", "parallel", "에이전트", "agent", "조정", "coordination", "파이프라인", "pipeline", "ACE"],
      "intentPatterns": [
        "(병렬|parallel).*?(작업|task|agent)",
        "(multi|여러).*?(agent|에이전트)",
        "(coordinate|조정).*?(task|작업)",
        "(parallel|concurrent|병렬).*(agent|task|execution|작업)",
        "(coordinate|orchestrate|조율).*(agent|worker|에이전트)",
        "(빌드|build).*?(배포|deploy).*?(검증|verify)",
        "(에러|error|장애).*?(분석|diagnose|investigate)",
        "(기능|feature).*?(설계|design).*?(구현|implement).*?(테스트|test)"
      ]
    },
    "pipelines": {
      "build-deploy-verify": {
        "trigger": "(빌드|build).*(배포|deploy)",
        "stages": ["kiips-build", "kiips-test-runner", "kiips-logs"],
        "managers": "build-manager, deployment-manager"
      },
      "feature-lifecycle": {
        "trigger": "(기능|feature).*(개발|develop|구현|implement)",
        "stages": ["kiips-architect", "legacy-compliance-checker", "kiips-developer", "kiips-ui-designer", "kiips-test-runner", "code-simplifier"],
        "managers": "feature-manager"
      },
      "incident-response": {
        "trigger": "(에러|error|장애|incident).*(분석|analyze|조사|investigate)",
        "stages": ["kiips-logs", "kiips-db-inspector"],
        "managers": "deployment-manager"
      }
    }
  },

  "kiips-scss": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "KiiPS SCSS 테마 시스템 - 디자인 토큰, 믹스인, 다크테마 [data-theme=dark] 적용",
    "promptTriggers": {
      "keywords": ["SCSS", "스타일", "테마", "다크테마", "dark theme", "CSS 변수", "믹스인"],
      "intentPatterns": [
        "SCSS.*?(setup|설정|create|생성)",
        "(theme|테마).*?(manage|관리|change|변경)",
        "(design token|디자인 토큰).*?",
        "(mixin|믹스인).*?(create|생성|add|추가)",
        "(style|스타일).*?(guide|가이드|system|시스템)",
        "(다크|dark).*(테마|theme|모드|mode).*(적용|apply)",
        "(apply|적용).*(dark|다크)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.scss", "**/_*.scss", "**/css/sass/**/*.scss", "**/themes/**/_dark.scss"],
      "contentPatterns": ["@import", "@mixin", "$primary", "$theme", "[data-theme=dark]", "$dark-bg", "$dark-color"]
    },
    "referenceFiles": ["docs/SCSS_GUIDE.md"]
  },

  "kiips-quality": {
    "type": "validation",
    "enforcement": "require",
    "priority": "high",
    "description": "KiiPS UI 품질 검증 - WCAG 2.1 AA 접근성, 반응형 디자인, 터치 타겟",
    "promptTriggers": {
      "keywords": ["접근성", "WCAG", "ARIA", "반응형", "responsive", "모바일", "터치 타겟", "a11y"],
      "intentPatterns": [
        "(accessibility|접근성|a11y).*?(check|검증|validate|test)",
        "WCAG.*?(verify|check|validate)",
        "ARIA.*?(label|role|attribute)",
        "(screen reader|스크린 리더).*?",
        "(keyboard|키보드).*?(navigation|네비게이션|nav)",
        "(responsive|반응형).*?(test|테스트|check|확인|validate|검증)",
        "(mobile|모바일).*?(layout|레이아웃|view|화면)",
        "(breakpoint|브레이크포인트).*?",
        "(touch|터치).*?(target|타겟)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": ["**/*.jsp", "**/*.html", "**/*.scss", "**/*.css"],
      "contentPatterns": ["aria-", "role=", "alt=", "label", "@media", "col-md-", "col-lg-", "img-fluid"]
    },
    "referenceFiles": ["docs/SCSS_GUIDE.md"]
  },

  "kiips-learning": {
    "type": "domain",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "KiiPS 학습 시스템 - Instinct 생성, 패턴 감지, 스킬 팩토리",
    "promptTriggers": {
      "keywords": ["학습", "패턴", "instinct", "skill factory", "스킬 생성", "자동화 제안"],
      "intentPatterns": [
        "(학습|learning|instinct).*?(패턴|pattern)",
        "(스킬|skill).*?(생성|create|factory)",
        "(관찰|observe).*?(분석|analyze)"
      ]
    }
  }
}
