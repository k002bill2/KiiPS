{
  "version": "1.0.0",
  "description": "Gemini CLI 스킬 자동 활성화 규칙 - 분석 전용 스킬만 포함",
  "globalRules": {
    "role": "read-only-analyst",
    "outputDir": ".temp/coordination/cross-tool/responses/",
    "forbiddenActions": [
      "코드 파일 직접 수정",
      "Maven/Gradle 빌드 실행",
      "서비스 시작/중지",
      "DB 직접 쿼리 실행"
    ]
  },
  "skills": [
    {
      "name": "security-scan",
      "path": ".gemini/skills/security-scan/SKILL.md",
      "promptTriggers": [
        "보안 감사", "security scan", "SQL injection", "XSS", "취약점", "vulnerability",
        "MyBatis", "${}", "하드코딩", "hardcoded"
      ],
      "fileTriggers": ["**/*Mapper.xml", "**/mapper/**/*.xml", "**/*.jsp"],
      "priority": "critical",
      "autoActivate": true
    },
    {
      "name": "codebase-audit",
      "path": ".gemini/skills/codebase-audit/SKILL.md",
      "promptTriggers": [
        "코드베이스 감사", "codebase audit", "전체 스캔", "API 패턴",
        "네이밍 일관성", "의존성 맵", "dependency map", "Cross-module"
      ],
      "fileTriggers": ["**/pom.xml", "**/*Controller.java"],
      "priority": "high",
      "autoActivate": true
    },
    {
      "name": "impact-analyzer",
      "path": ".gemini/skills/impact-analyzer/SKILL.md",
      "promptTriggers": [
        "영향도 분석", "impact analysis", "변경 영향", "COMMON 변경",
        "UTILS 변경", "공통 모듈", "참조 체인", "breaking change"
      ],
      "fileTriggers": [
        "KiiPS-COMMON/src/**/*.java",
        "KiiPS-UTILS/src/**/*.java"
      ],
      "priority": "high",
      "autoActivate": true
    }
  ],
  "legacySkills": {
    "description": "아래 스킬들은 Claude Code 전담입니다. Gemini에서는 분석 참조용으로만 사용하고 실행하지 마세요.",
    "claudeOnly": [
      "kiips-maven-builder",
      "kiips-service-deployer",
      "kiips-darktheme-applier",
      "kiips-startup",
      "kiips-test-runner",
      "verification-loop"
    ]
  }
}
