{
  "jsp-spring-patterns": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "critical",
    "description": "JSP + Spring Boot 핵심 패턴 가이드",
    "promptTriggers": {
      "keywords": [
        "controller",
        "service",
        "repository",
        "mapper",
        "jsp",
        "컨트롤러",
        "서비스"
      ],
      "intentPatterns": [
        "(create|add|make).*?(controller|service|mapper|jsp)",
        "(fix|debug).*?(controller|service|repository)",
        "(생성|만들|추가).*?(컨트롤러|서비스|매퍼|화면)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/controller/**/*.java",
        "**/service/**/*.java",
        "**/mapper/**/*.xml",
        "**/WEB-INF/jsp/**/*.jsp"
      ],
      "contentPatterns": [
        "@Controller",
        "@Service",
        "@Transactional",
        "SqlSession"
      ]
    }
  },
  "mybatis-sql-safety": {
    "type": "guardrail",
    "enforcement": "block",
    "priority": "critical",
    "description": "MyBatis SQL Injection 방지 - ${} 대신 #{} 사용",
    "promptTriggers": {
      "keywords": [
        "mapper",
        "mybatis",
        "sql",
        "query",
        "쿼리"
      ],
      "intentPatterns": [
        "(write|create|add).*?(sql|query|mapper)",
        "(mybatis|마이바티스).*?(insert|update|delete|select)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/mapper/**/*.xml"
      ],
      "contentPatterns": [
        "${",
        "#{",
        "<select",
        "<insert",
        "<update",
        "<delete"
      ]
    },
    "blockedPatterns": [
      "${.*}"
    ],
    "reminder": "SQL Injection 방지: ${} 대신 #{} 파라미터 바인딩을 사용하세요 (ORDER BY 등 동적 SQL 제외)"
  },
  "transactional-management": {
    "type": "guardrail",
    "enforcement": "require",
    "priority": "critical",
    "description": "@Transactional 범위 및 롤백 관리",
    "promptTriggers": {
      "keywords": [
        "transaction",
        "transactional",
        "rollback",
        "트랜잭션",
        "롤백"
      ],
      "intentPatterns": [
        "(add|use).*?transactional",
        "(rollback|롤백).*?(exception|error)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/service/**/*.java"
      ],
      "contentPatterns": [
        "@Transactional",
        "rollbackFor",
        "propagation"
      ]
    },
    "reminder": "@Transactional(rollbackFor = Exception.class)로 명시적 롤백 설정 필수"
  },
  "dark-theme-scss": {
    "type": "guardrail",
    "enforcement": "block",
    "priority": "critical",
    "description": "다크테마 SCSS 규칙 준수",
    "promptTriggers": {
      "keywords": [
        "dark",
        "theme",
        "scss",
        "다크",
        "테마",
        "다크테마",
        "다크모드"
      ],
      "intentPatterns": [
        "(dark|다크).*?(theme|테마|모드)",
        "(scss|style).*?(dark|theme)",
        "(apply|적용).*?(dark|다크)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/css/sass/**/*.scss",
        "**/themes/**/_dark.scss",
        "**/layouts/_dark.scss"
      ],
      "contentPatterns": [
        "[data-theme=dark]",
        "$dark-bg",
        "$dark-color"
      ]
    },
    "blockedPatterns": [
      ".dark ",
      ".theme-dark",
      "width:",
      "height:",
      "display:",
      "position:",
      "margin:",
      "padding:"
    ],
    "reminder": "[data-theme=dark] 셀렉터만 사용, .dark/.theme-dark 금지, 레이아웃 속성 변경 금지, SCSS 변수 활용"
  },
  "button-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "KiiPS 버튼 영역 패턴 - inc_main_button, 권한, 아이콘",
    "promptTriggers": {
      "keywords": [
        "버튼",
        "툴바",
        "inc_main_button",
        "btn_reload",
        "btn_regist",
        "icon_",
        "관리자 버튼",
        "엑셀 버튼"
      ],
      "intentPatterns": [
        "(버튼|toolbar|툴바).*(추가|생성|만들|수정)",
        "(create|add|make).*(button|toolbar)",
        "inc_(il|fd|ac|pg)_button"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/include/button/inc_*_button.jsp",
        "**/include/inc_main_button.jsp"
      ],
      "contentPatterns": [
        "inc_main_button",
        "maingrid_button",
        "btn_reload",
        "btn_regist"
      ]
    },
    "reminder": "inc_main_button.jsp Include 필수, 도메인별 버튼 파일에 MENU_SCREEN_ID 분기 추가, 권한(A/C/E) 체크"
  },
  "page-pattern-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "KiiPS JSP 페이지 표준 패턴 - 레이아웃, Include 체계, 검색필터+버튼+그리드 연동",
    "promptTriggers": {
      "keywords": [
        "페이지 생성",
        "화면 만들",
        "JSP 만들",
        "새 화면",
        "페이지 패턴",
        "표준 패턴",
        "페이지 템플릿",
        "화면 추가",
        "목록 화면",
        "CRUD 화면",
        "page pattern"
      ],
      "intentPatterns": [
        "(페이지|화면|JSP).*(생성|만들|추가|제작)",
        "(create|add|make).*(page|screen|jsp)",
        "(표준|standard).*(패턴|pattern).*(적용|apply)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/WEB-INF/jsp/kiips/**/*.jsp"
      ],
      "contentPatterns": [
        "inc_filter_main",
        "inc_main_button",
        "MAIN_SEARCH_FILTER",
        "content-body-modern"
      ]
    },
    "reminder": "표준 Include 순서 준수 (header→sidemenu→inc_files), inc_{domain}_button.jsp 분기 등록 필수, MAIN_SEARCH_FILTER() 패턴 사용"
  },
  "search-filter-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "KiiPS 검색필터 패턴 - MainComponent, Constant, inc_filter_main.jsp 연동",
    "promptTriggers": {
      "keywords": [
        "검색조건",
        "검색필터",
        "SEARCH_CONDITION",
        "MainComponent",
        "필터",
        "inc_filter_main",
        "필터 추가",
        "조건 추가"
      ],
      "intentPatterns": [
        "(검색|필터|조건).*(추가|생성|만들|수정)",
        "(create|add|make).*(filter|search|condition)",
        "SEARCH_CONDITION.*(추가|변경|수정)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/WEB-INF/jsp/**/*.jsp"
      ],
      "contentPatterns": [
        "SEARCH_CONDITION",
        "MainComponent",
        "inc_filter_main",
        "MAIN_SEARCH_FILTER"
      ]
    },
    "reminder": "MainComponent 빌더 패턴 사용, SEARCH_CONDITION에 | 구분으로 추가, 인라인 HTML 필터 금지"
  },
  "realgrid-development": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "RealGrid 2.6.3 그리드 개발 패턴",
    "promptTriggers": {
      "keywords": [
        "realgrid",
        "grid",
        "gridview",
        "dataprovider",
        "그리드",
        "리얼그리드"
      ],
      "intentPatterns": [
        "(create|add|make).*?(grid|table|realgrid)",
        "(생성|만들).*?(그리드|테이블)",
        "realgrid.*?(설정|config|setup)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/WEB-INF/jsp/**/*.jsp"
      ],
      "contentPatterns": [
        "GridView",
        "LocalDataProvider",
        "setColumns",
        "setFields"
      ]
    },
    "reminder": "GridView + DataProvider 초기화 필수, 이벤트 핸들러 정리(메모리 누수 방지), Excel Export 기능 확인"
  },
  "api-gateway-routing": {
    "type": "domain",
    "enforcement": "require",
    "priority": "high",
    "description": "API Gateway 라우팅 및 서비스 간 통신",
    "promptTriggers": {
      "keywords": [
        "gateway",
        "routing",
        "api",
        "x-api-key",
        "게이트웨이",
        "라우팅"
      ],
      "intentPatterns": [
        "(api|gateway).*?(route|routing|endpoint)",
        "(service|서비스).*?(call|통신|호출)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/KIIPS-APIGateway/**/*.java",
        "**/KIIPS-APIGateway/**/*.yml"
      ],
      "contentPatterns": [
        "x-api-key",
        "RouteLocator",
        "GatewayFilter"
      ]
    },
    "reminder": "Gateway 포트 8088, x-api-key 헤더 검증 필수, Common_API_Service로 서비스 간 호출"
  },
  "maven-build": {
    "type": "workflow",
    "enforcement": "require",
    "priority": "high",
    "description": "Maven Multi-Module 빌드 규칙",
    "promptTriggers": {
      "keywords": [
        "maven",
        "build",
        "pom",
        "빌드",
        "메이븐",
        "패키지"
      ],
      "intentPatterns": [
        "(maven|mvn).*?(build|package|compile)",
        "(빌드|컴파일).*?(service|모듈)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/pom.xml"
      ],
      "contentPatterns": [
        "<artifactId>",
        "<dependency>",
        "<module>"
      ]
    },
    "reminder": "항상 KiiPS-HUB에서 빌드, 빌드 순서: COMMON -> UTILS -> 서비스, SNAPSHOT 버전 프로덕션 배포 금지"
  },
  "error-handling": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "에러 처리 및 Sentry 통합",
    "promptTriggers": {
      "keywords": [
        "error",
        "exception",
        "catch",
        "에러",
        "오류",
        "예외"
      ],
      "intentPatterns": [
        "(handle|catch).*?(error|exception)",
        "(global|공통).*?(exception|에러).*?handler"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/exception/**/*.java",
        "**/controller/**/*.java"
      ],
      "contentPatterns": [
        "@ExceptionHandler",
        "GlobalExceptionHandler",
        "ResponseEntity"
      ]
    },
    "reminder": "GlobalExceptionHandler에서 커버하는 예외 타입 확인, ResponseEntity로 적절한 HTTP 상태 코드 반환"
  },
  "ajax-patterns": {
    "type": "guideline",
    "enforcement": "require",
    "priority": "high",
    "description": "jQuery AJAX 패턴 및 에러 처리",
    "promptTriggers": {
      "keywords": [
        "ajax",
        "jquery",
        "fetch",
        "에이잭스",
        "비동기 호출"
      ],
      "intentPatterns": [
        "(ajax|jquery).*?(call|request|호출)",
        "(비동기|async).*?(호출|요청)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/WEB-INF/jsp/**/*.jsp",
        "**/static/js/**/*.js"
      ],
      "contentPatterns": [
        "$.ajax",
        "$.post",
        "$.get",
        ".fail(",
        ".done("
      ]
    },
    "reminder": "AJAX 에러 핸들러(.fail()) 필수, Loading 스피너 표시/숨기기, 중복 요청 방지(버튼 비활성화)"
  },
  "code-simplifier": {
    "type": "agent",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "코드 단순화 및 리팩토링",
    "agentFile": ".claude/agents/code-simplifier.md",
    "model": "haiku",
    "promptTriggers": {
      "keywords": [
        "simplify",
        "refactor",
        "단순화",
        "리팩토링",
        "개선"
      ],
      "intentPatterns": [
        "(simplify|refactor).*?(code|function)",
        "(reduce|줄이).*?(complexity|복잡도)"
      ]
    }
  },
  "parallel-coordinator": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "ACE Framework 기반 병렬 에이전트 실행 조율",
    "promptTriggers": {
      "keywords": [
        "parallel",
        "concurrent",
        "multi-agent",
        "coordinate",
        "ACE"
      ],
      "intentPatterns": [
        "(parallel|concurrent).*?(agent|task|execution)",
        "(coordinate|orchestrate).*?(agent|worker)"
      ]
    }
  },
  "checklist-generator": {
    "type": "tool",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "자동 체크리스트 생성",
    "promptTriggers": {
      "keywords": [
        "checklist",
        "체크리스트",
        "TODO",
        "확인사항"
      ],
      "intentPatterns": [
        "(create|generate).*?(checklist|todo)",
        "(verify|check).*?list"
      ]
    }
  },
  "verification-loop": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Boris Cherny 스타일 검증 피드백 루프 (컴파일 -> 테스트 -> 빌드)",
    "promptTriggers": {
      "keywords": [
        "verify",
        "verification",
        "feedback loop",
        "검증",
        "확인"
      ],
      "intentPatterns": [
        "(verify|validate).*?(code|app)",
        "(feedback|verification).*?loop"
      ]
    }
  },
  "dev-docs-workflow": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "Dev Docs 시스템 - 대규모 작업 전 계획/컨텍스트 저장",
    "promptTriggers": {
      "keywords": [
        "dev docs",
        "plan",
        "context",
        "대규모 작업",
        "큰 작업"
      ],
      "intentPatterns": [
        "(create|make).*?(dev docs|plan)",
        "(large|big|대규모).*?(task|작업|feature)"
      ]
    },
    "reminder": "대규모 작업 전 /dev-docs 실행 권장, context 부족 시 /save-and-compact"
  },
  "hook-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Claude Code Hook 생성 및 설정",
    "promptTriggers": {
      "keywords": [
        "hook",
        "hooks",
        "PreToolUse",
        "PostToolUse"
      ],
      "intentPatterns": [
        "(create|make|add).*?hook",
        "(configure|setup).*?hook"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        ".claude/hooks/**"
      ]
    }
  },
  "skill-creator": {
    "type": "meta",
    "enforcement": "suggest",
    "priority": "normal",
    "description": "Claude Code Skill 생성 가이드",
    "promptTriggers": {
      "keywords": [
        "skill",
        "create skill",
        "SKILL.md"
      ],
      "intentPatterns": [
        "(create|make|add).*?skill"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        ".claude/skills/**"
      ]
    }
  },
  "agent-observability": {
    "type": "infrastructure",
    "enforcement": "suggest",
    "priority": "medium",
    "description": "에이전트 추적 및 메트릭 (agentTracer, contextMonitor)",
    "promptTriggers": {
      "keywords": [
        "trace",
        "metrics",
        "observability",
        "monitoring"
      ],
      "intentPatterns": [
        "(trace|track).*?(agent|workflow)",
        "(monitor|observe).*?performance"
      ]
    }
  },
  "security-patterns": {
    "type": "guardrail",
    "enforcement": "block",
    "priority": "critical",
    "description": "보안 패턴 - API 키, 비밀번호, 프로덕션 설정 보호",
    "promptTriggers": {
      "keywords": [
        "security",
        "password",
        "api key",
        "보안",
        "비밀번호"
      ],
      "intentPatterns": [
        "(hardcode|하드코딩).*?(password|key|비밀번호)",
        "(commit|커밋).*?(env|properties|secret)"
      ]
    },
    "blockedPatterns": [
      "app-kiips.properties",
      "app-stg.properties",
      ".env"
    ],
    "reminder": "프로덕션 설정 파일 커밋 금지, API 키/비밀번호 하드코딩 금지, XSS/CSRF 방지"
  },
  "deployment-workflow": {
    "type": "workflow",
    "enforcement": "require",
    "priority": "high",
    "description": "서비스 배포 워크플로우 (빌드 → 테스트 → 배포 → 헬스체크)",
    "promptTriggers": {
      "keywords": [
        "deploy",
        "배포",
        "start",
        "stop",
        "restart",
        "시작",
        "중지",
        "재시작"
      ],
      "intentPatterns": [
        "(deploy|배포).*?(service|서비스)",
        "(start|stop|restart).*?(service|서비스|server|서버)",
        "(시작|중지|재시작).*?(서비스|서버)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/start.sh",
        "**/stop.sh",
        "**/deploy*.sh"
      ]
    },
    "reminder": "배포 전 mvn package 성공 확인, 포트 충돌 체크, 의존 서비스 실행 확인, 헬스체크 후 완료 보고"
  },
  "api-testing": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "high",
    "description": "API 엔드포인트 테스트 및 헬스체크",
    "promptTriggers": {
      "keywords": [
        "api test",
        "health check",
        "endpoint",
        "헬스체크",
        "API 테스트",
        "엔드포인트"
      ],
      "intentPatterns": [
        "(test|테스트).*?(api|endpoint|엔드포인트)",
        "(health|헬스).*?(check|체크)",
        "(verify|확인).*?(api|서비스)"
      ]
    },
    "reminder": "x-api-key 헤더 포함, Gateway(8088) 경유 테스트, 응답 코드/형식 검증"
  },
  "regist-modal-guide": {
    "type": "domain",
    "enforcement": "require",
    "priority": "critical",
    "description": "KiiPS 등록/수정 모달 패턴 - 모달 HTML, 폼필드, 편집그리드, columnGroup 머지, 저장",
    "promptTriggers": {
      "keywords": [
        "등록 모달",
        "수정 모달",
        "모달창",
        "팝업",
        "registModal",
        "modal 생성",
        "모달 추가",
        "등록모달",
        "모달 그리드"
      ],
      "intentPatterns": [
        "(등록|수정|모달|팝업).*(생성|만들|추가)",
        "modal.*(add|create)",
        "(columnGroup|컬럼그룹).*(머지|merge)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/WEB-INF/jsp/**/*.jsp"
      ],
      "contentPatterns": [
        "modal fade",
        "modal-dialog",
        "bottom-btn",
        "modal-confirm"
      ]
    },
    "reminder": "모달 ID 고유, backdrop static, z-index 1060+, bottom-btn 필수, hide.bs.modal에서 initComponent + clearRows"
  },
  "log-analysis": {
    "type": "workflow",
    "enforcement": "suggest",
    "priority": "medium",
    "description": "서비스 로그 분석 및 에러 추적",
    "promptTriggers": {
      "keywords": [
        "log",
        "로그",
        "error",
        "에러",
        "exception",
        "stack trace",
        "스택트레이스"
      ],
      "intentPatterns": [
        "(analyze|분석).*?(log|로그)",
        "(find|찾|검색).*?(error|에러|exception)",
        "(tail|view|조회).*?(log|로그)"
      ]
    },
    "fileTriggers": {
      "pathPatterns": [
        "**/logs/**/*.log"
      ]
    },
    "reminder": "로그 경로: logs/log.$(date '+%Y-%m-%d')-0.log, Sentry 이벤트 확인, 에러 패턴 분류"
  }
}
