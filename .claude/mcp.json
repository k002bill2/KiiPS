{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "obsidian-mcp-rest",
        "--vault-path",
        "${OBSIDIAN_VAULT_PATH}"
      ],
      "env": {
        "OBSIDIAN_VAULT_PATH": "${OBSIDIAN_VAULT_PATH}"
      },
      "disabled": true,
      "_setup": "1) export OBSIDIAN_VAULT_PATH='/Users/$USER/Library/Mobile Documents/iCloud~md~obsidian/Documents/MyVault' 2) Set disabled:false 3) Restart Claude Code"
    }
  }
}
