{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ./.claude/hooks/ethicalValidator.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys; p=json.load(sys.stdin).get('tool_input',{}).get('file_path',''); blocked=['.env','secrets','.git/','app-kiips.properties','app-stg.properties','app-local.properties','app-tibero.properties','credentials','.secret','password']; sys.exit(2 if any(b in p for b in blocked) else 0)\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ./.claude/hooks/userPromptSubmit.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ./.claude/hooks/autoFormatter.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ./.claude/hooks/buildChecker.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./.claude/hooks/scssValidator.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./.claude/hooks/gemini-collector.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ./.claude/hooks/outputSecretFilter.js"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ./.claude/hooks/observe.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\" && test -f ./.claude/hooks/stopEvent.js && node ./.claude/hooks/stopEvent.js || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./.claude/hooks/pre-compact-save.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ./.claude/hooks/notificationHandler.js 2>>.claude/hooks/hook-errors.log || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./.claude/hooks/update-reminder.sh"
          },
          {
            "type": "command",
            "command": "node ./.claude/hooks/crossToolReader.js 2>>.claude/hooks/hook-errors.log || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "permissionRules": [
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "rm -rf:*",
      "description": "Prevent recursive file deletion"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "rm:*",
      "description": "Prevent file deletion without approval"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "DROP:*",
      "description": "Prevent database DROP commands"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "TRUNCATE:*",
      "description": "Prevent database TRUNCATE commands"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "DELETE FROM:*",
      "description": "Prevent database DELETE commands"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "sudo:*",
      "description": "Prevent sudo commands"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "*:.env*",
      "description": "Prevent any command accessing .env files"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "*:*app-kiips.properties*",
      "description": "Prevent accessing production config via Bash"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "*:*app-stg.properties*",
      "description": "Prevent accessing staging config via Bash"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "*:*app-local.properties*",
      "description": "Prevent accessing local dev config via Bash"
    },
    {
      "type": "deny",
      "tool": "Bash",
      "pattern": "*:*app-tibero.properties*",
      "description": "Prevent accessing Tibero DB config via Bash"
    },
    {
      "type": "deny",
      "tool": "Read",
      "pattern": "**/.env*",
      "description": "Prevent reading environment secrets"
    },
    {
      "type": "deny",
      "tool": "Read",
      "pattern": "**/password*",
      "description": "Prevent reading password files"
    },
    {
      "type": "deny",
      "tool": "Read",
      "pattern": "**/app-kiips.properties",
      "description": "Prevent reading production config"
    },
    {
      "type": "deny",
      "tool": "Read",
      "pattern": "**/app-stg.properties",
      "description": "Prevent reading staging config"
    },
    {
      "type": "deny",
      "tool": "Read",
      "pattern": "**/app-local.properties",
      "description": "Prevent reading local dev config"
    },
    {
      "type": "deny",
      "tool": "Read",
      "pattern": "**/app-tibero.properties",
      "description": "Prevent reading Tibero DB config"
    },
    {
      "type": "deny",
      "tool": "Edit",
      "pattern": "**/.env*",
      "description": "Prevent editing environment secrets"
    },
    {
      "type": "deny",
      "tool": "Edit",
      "pattern": "**/app-kiips.properties",
      "description": "Prevent editing production config"
    },
    {
      "type": "deny",
      "tool": "Edit",
      "pattern": "**/app-stg.properties",
      "description": "Prevent editing staging config"
    },
    {
      "type": "deny",
      "tool": "Edit",
      "pattern": "**/app-local.properties",
      "description": "Prevent editing local dev config"
    },
    {
      "type": "deny",
      "tool": "Edit",
      "pattern": "**/app-tibero.properties",
      "description": "Prevent editing Tibero DB config"
    },
    {
      "type": "deny",
      "tool": "Write",
      "pattern": "**/.env*",
      "description": "Prevent overwriting environment secrets"
    },
    {
      "type": "deny",
      "tool": "Write",
      "pattern": "**/app-kiips.properties",
      "description": "Prevent overwriting production config"
    },
    {
      "type": "deny",
      "tool": "Write",
      "pattern": "**/app-stg.properties",
      "description": "Prevent overwriting staging config"
    },
    {
      "type": "deny",
      "tool": "Write",
      "pattern": "**/app-local.properties",
      "description": "Prevent overwriting local dev config"
    },
    {
      "type": "deny",
      "tool": "Write",
      "pattern": "**/app-tibero.properties",
      "description": "Prevent overwriting Tibero DB config"
    },
    {
      "type": "deny",
      "tool": "Grep",
      "pattern": "**/.env*",
      "description": "Prevent searching environment secrets"
    },
    {
      "type": "deny",
      "tool": "Grep",
      "pattern": "**/app-kiips.properties",
      "description": "Prevent searching production config"
    },
    {
      "type": "deny",
      "tool": "Grep",
      "pattern": "**/app-stg.properties",
      "description": "Prevent searching staging config"
    },
    {
      "type": "deny",
      "tool": "Grep",
      "pattern": "**/app-local.properties",
      "description": "Prevent searching local dev config"
    },
    {
      "type": "deny",
      "tool": "Grep",
      "pattern": "**/app-tibero.properties",
      "description": "Prevent searching Tibero DB config"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "mvn:*",
      "description": "Allow Maven commands for building KiiPS modules"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "java:*",
      "description": "Allow Java commands for running services"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "svn:*",
      "description": "Allow SVN commands (KiiPS uses SVN for version control)"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "git:*",
      "description": "Allow Git commands"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "./start.sh:*",
      "description": "Allow starting KiiPS services"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "./stop.sh:*",
      "description": "Allow stopping KiiPS services"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "tail:*",
      "description": "Allow viewing log files"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "cat:*",
      "description": "Allow reading file contents"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "grep:*",
      "description": "Allow searching in files"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "find:*",
      "description": "Allow finding files"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "ls:*",
      "description": "Allow listing directories"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "mkdir:*",
      "description": "Allow creating directories"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "node ./.claude/hooks/gemini-bridge.js:*",
      "description": "Allow Gemini bridge execution for code review"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "gemini:*",
      "description": "Allow Gemini CLI binary execution"
    },
    {
      "type": "allow",
      "tool": "Bash",
      "pattern": "mkdir:./.claude/gemini-bridge*",
      "description": "Allow creating gemini-bridge directories"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.java",
      "description": "Allow reading Java source files"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.xml",
      "description": "Allow reading XML configuration files (pom.xml, etc.)"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.properties",
      "description": "Allow reading properties files (blocked ones excluded by deny above)"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.jsp",
      "description": "Allow reading JSP files"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.js",
      "description": "Allow reading JavaScript files"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.css",
      "description": "Allow reading CSS files"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.scss",
      "description": "Allow reading SCSS files"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.sh",
      "description": "Allow reading shell scripts"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.md",
      "description": "Allow reading markdown files"
    },
    {
      "type": "allow",
      "tool": "Read",
      "pattern": "**/*.json",
      "description": "Allow reading JSON files"
    }
  ],
  "mcpContextUris": [],
  "thinking": {
    "enabled": true,
    "mode": "auto"
  },
  "autoAcceptEdits": false,
  "contextWindowWarningThreshold": 0.8,
  "lsp": {
    "java": {
      "command": "/opt/homebrew/bin/jdtls",
      "args": [
        "-data",
        "${workspaceFolder}/.jdt"
      ],
      "initializationOptions": {
        "workspace": "${workspaceFolder}",
        "settings": {
          "java": {
            "home": "/opt/homebrew/opt/openjdk/libexec/openjdk.jdk/Contents/Home",
            "configuration": {
              "runtimes": [
                {
                  "name": "JavaSE-1.8",
                  "path": "/Library/Java/JavaVirtualMachines/jdk-1.8.jdk/Contents/Home",
                  "default": true
                }
              ]
            },
            "project": {
              "referencedLibraries": [
                "**/*.jar"
              ]
            },
            "maven": {
              "downloadSources": true,
              "downloadJavadoc": false
            }
          }
        }
      },
      "rootPatterns": [
        "pom.xml",
        ".git"
      ],
      "filetypes": [
        "java"
      ]
    }
  }
}
