# MCP Server API Keys
# Copy this file to .env.mcp and fill in your actual API keys
# NEVER commit .env.mcp to version control!

# Anthropic API Key for Claude models (Required for Task Master)
ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY}

# Perplexity API Key for research features (Highly recommended for Task Master)
PERPLEXITY_API_KEY: ${PERPLEXITY_API_KEY}

OPENAI_API_KEY: ${OPENAI_API_KEY}
GOOGLE_API_KEY: ${GOOGLE_API_KEY}
MISTRAL_API_KEY: ${MISTRAL_API_KEY}
XAI_API_KEY: ${XAI_API_KEY}
GROQ_API_KEY: ${GROQ_API_KEY}
OPENROUTER_API_KEY: ${OPENROUTER_API_KEY}
AZURE_OPENAI_API_KEY: ${AZURE_OPENAI_API_KEY}
OLLAMA_API_KEY: ${OLLAMA_API_KEY}
GITHUB_API_KEY: ${GITHUB_API_KEY}


# OpenAI API Key (Optional)
# OPENAI_API_KEY=your_openai_api_key_here

# Google API Key for Gemini (Optional)
# GOOGLE_API_KEY=your_google_api_key_here

# Other optional providers
# XAI_API_KEY=your_xai_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# MISTRAL_API_KEY=your_mistral_api_key_here
